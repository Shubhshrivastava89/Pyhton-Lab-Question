<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vision-Based Child Wellness Shield</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:#020b1f;
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    color:white;
}

.container{
    width:95%;
    max-width:1400px;
    padding:30px;
    border-radius:20px;
    background:rgba(0,0,0,0.65);
    box-shadow:0 0 30px rgba(0,255,255,0.2);
}

.title{
    text-align:center;
    font-size:42px;
    font-weight:bold;
    color:#00eaff;
    text-shadow:0 0 15px #00eaff;
    margin-bottom:10px;
}

.subtitle{
    text-align:center;
    font-size:20px;
    color:#ffd54f;
    margin-bottom:40px;
}

.main-box{
    display:flex;
    gap:40px;
    justify-content:center;
    flex-wrap:wrap;
}

/* Left Panel */
.upload-panel{
    width:420px;
    min-height:520px;
    background:#111;
    border-radius:18px;
    padding:30px;
    box-shadow:0 0 20px #00eaff;
}

.upload-panel h2{
    text-align:center;
    color:#00eaff;
    margin-bottom:30px;
    font-size:32px;
}

input[type=file]{
    width:100%;
    padding:10px;
    border:2px solid #00eaff;
    border-radius:8px;
    background:black;
    color:white;
}

button{
    margin:30px auto;
    display:block;
    padding:15px 30px;
    font-size:18px;
    border:none;
    border-radius:10px;
    background:#00eaff;
    color:black;
    cursor:pointer;
    box-shadow:0 0 15px #00eaff;
    transition:0.3s;
}

button:hover{
    transform:scale(1.05);
}

.line{
    width:80%;
    height:4px;
    margin:20px auto;
    background:#00eaff;
    box-shadow:0 0 10px #00eaff;
}

/* Right Panel */
.report-panel{
    width:480px;
    min-height:520px;
    background:#111;
    border-radius:18px;
    padding:30px;
    box-shadow:0 0 20px gold;
}

.report-panel h2{
    text-align:center;
    color:#00eaff;
    font-size:32px;
    margin-bottom:25px;
}

table{
    width:100%;
    border-collapse:collapse;
    overflow:hidden;
    border-radius:10px;
}

th{
    background:#00d8ff;
    color:white;
    padding:15px;
    font-size:18px;
}

td{
    padding:16px;
    text-align:center;
    border:1px solid rgba(255,255,255,0.08);
    color:white;
}

.footer-line{
    width:100%;
    height:12px;
    margin-top:15px;
    border-radius:8px;
    background:#2d3b4f;
}

.footer{
    text-align:center;
    margin-top:25px;
    color:#ccc;
    font-size:16px;
}
</style>
</head>

<body>

<div class="container">

    <div class="title">Vision-Based Child Wellness Shield</div>
    <div class="subtitle">AI Driven Health Monitoring System</div>

    <div class="main-box">

        <!-- Upload Section -->
        <div class="upload-panel">
            <h2>Upload Image</h2>

            <input type="file">

            <button>Analyze with AI</button>

            <div class="line"></div>
        </div>

        <!-- Report Section -->
        <div class="report-panel">
            <h2>Health Report</h2>

            <table>
                <tr>
                    <th>Parameter</th>
                    <th>Value</th>
                </tr>
                <tr><td>BMI</td><td>--</td></tr>
                <tr><td>Height</td><td>--</td></tr>
                <tr><td>Weight</td><td>--</td></tr>
                <tr><td>Age</td><td>--</td></tr>
                <tr><td>Status</td><td>--</td></tr>
                <tr><td>Health</td><td>--</td></tr>
            </table>

            <div class="footer-line"></div>
        </div>

    </div>

    <div class="footer">
        AI Powered Child Health Detection | Computer Vision Project
    </div>

</div>

</body>
</html>
